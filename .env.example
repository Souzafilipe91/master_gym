# ─── Banco de Dados (PostgreSQL) ──────────────────────────────────────────────
# Crie gratuitamente em https://neon.tech → copie a connection string
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui

# ─── Inteligência Artificial (Anthropic Claude) ───────────────────────────────
# Obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Autenticação Google OAuth ────────────────────────────────────────────────
# Crie em https://console.cloud.google.com → APIs → Credenciais
# Redirect URI autorizado: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── Admin (opcional) ─────────────────────────────────────────────────────────
# E-mail que receberá role "admin" automaticamente no primeiro login
ADMIN_EMAIL=seu@email.com

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── CORS (produção) ──────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://seu-dominio.com

# ─── Google Maps (opcional) ───────────────────────────────────────────────────
# Necessário apenas se usar funcionalidades de mapa
# GOOGLE_MAPS_API_KEY=AIza...

# ─── Transcrição de voz (opcional) ───────────────────────────────────────────
# Necessário apenas se usar transcrição de áudio com Whisper
# OPENAI_API_KEY=sk-...
